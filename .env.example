# Firebase — create a free project at console.firebase.google.com
# Get these from: project settings → service account → generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Firebase client config — from project settings → your apps → web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# XRPL — generate a testnet wallet at faucet.altnet.rippletest.net
XRPL_SEED=

# Explorer base URL
# Testnet: https://testnet.xrpl.org/transactions
# Mainnet: https://xrpscan.com/tx
NEXT_PUBLIC_XRPL_EXPLORER=https://testnet.xrpl.org/transactions

# Optional — USF rippled node proxy
USF_PROXY_URL=
